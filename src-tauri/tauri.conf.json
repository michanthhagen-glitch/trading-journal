{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MethodMark",
  "mainBinaryName": "MethodMark",
  "version": "0.1.4",
  "identifier": "com.mykey.tradingjournal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MethodMark",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/screenshots/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis"],
    "category": "Productivity",
    "shortDescription": "MethodMark trading journal",
    "longDescription": "A local-first desktop journal for planning, recording, and reviewing trades as they happen.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/michanthhagen-glitch/trading-journal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxRjg4ODdEQzI4NjU2OTEKUldTUlZvYkNmWWo0Z1pnbi9USlh1aXV3T3BBY2FyTDhYK05VcC9CcXZnUTRJWk9aM1NNUlJyT1EK"
    }
  }
}
