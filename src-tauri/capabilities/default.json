{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for MethodMark",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-app-meta-recursive",
    "dialog:default",
    "dialog:allow-open",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-image"
  ]
}
