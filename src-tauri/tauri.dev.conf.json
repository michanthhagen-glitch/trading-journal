{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MethodMark Dev",
  "mainBinaryName": "MethodMark Dev",
  "identifier": "com.mykey.tradingjournal.dev",
  "build": {
    "beforeDevCommand": "npm run dev:dev-app",
    "beforeBuildCommand": "npm run build:dev-app"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MethodMark Dev",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "createUpdaterArtifacts": false,
    "shortDescription": "MethodMark Dev desktop",
    "longDescription": "Development build for testing MethodMark features without real trade data.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "windows/installer-hooks-dev.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
